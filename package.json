{
  "name": "enterprise-ops-dashboard-starter",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "An Excel-to-database data visualization management platform starter with topology, status rules, statistics, and report export.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check:contract": "node scripts/check-contract.mjs",
    "import:demo": "python3 scripts/import_demo_data.py --input examples/excel-sheets --db output/demo.db",
    "export:report": "python3 scripts/export_report.py --db output/demo.db --output output/report"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "vite": "^7.2.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
